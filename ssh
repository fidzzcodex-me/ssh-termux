#!/data/data/com.termux/files/usr/bin/bash
#
# ssh - SSH connection manager buat Termux
# Usage:
#   ssh create <nama>          -> bikin koneksi baru (interaktif)
#   ssh connect <nama>         -> konek ke koneksi tersimpan
#   ssh list                   -> list semua koneksi
#   ssh remove <nama>          -> hapus koneksi
#   ssh dc                     -> putus session SSH aktif
#   ssh <user>@<host> [...]    -> tetap bisa dipakai kayak ssh biasa (passthrough)
#
set -euo pipefail

CONF_DIR="$HOME/.ssh-manager"
CONN_DIR="$CONF_DIR/connections"
ACTIVE_FILE="$CONF_DIR/active_session"
REAL_SSH="$(command -v ssh || true)"
[ -z "$REAL_SSH" ] && REAL_SSH="/data/data/com.termux/files/usr/bin/ssh"

mkdir -p "$CONN_DIR"
chmod 700 "$CONF_DIR" "$CONN_DIR"

# ---------- helpers ----------

c_green() { printf '\033[1;32m%s\033[0m\n' "$1"; }
c_red()   { printf '\033[1;31m%s\033[0m\n' "$1"; }
c_yellow(){ printf '\033[1;33m%s\033[0m\n' "$1"; }
c_cyan()  { printf '\033[1;36m%s\033[0m\n' "$1"; }

die() { c_red "✗ $1"; exit 1; }

conn_file() { echo "$CONN_DIR/$1.conf"; }

require_openssl() {
    command -v openssl >/dev/null 2>&1 || die "openssl belum terinstall. Jalankan: pkg install openssl-tool"
}

# encrypt string -> stdout (base64)
encrypt_str() {
    local plain="$1" pass="$2"
    printf '%s' "$plain" | openssl enc -aes-256-cbc -pbkdf2 -salt -pass pass:"$pass" -base64
}

# decrypt base64 -> stdout
decrypt_str() {
    local enc="$1" pass="$2"
    printf '%s\n' "$enc" | openssl enc -aes-256-cbc -pbkdf2 -d -salt -pass pass:"$pass" -base64 2>/dev/null
}

ASKED_PASS=""
ask_master_pass() {
    local prompt="$1"
    read -rsp "$prompt" ASKED_PASS
    echo
}

# ---------- commands ----------

cmd_create() {
    local name="${1:-}"
    [ -z "$name" ] && die "Nama koneksi wajib diisi. Contoh: ssh create myvps"

    local file
    file="$(conn_file "$name")"
    [ -f "$file" ] && die "Koneksi '$name' sudah ada. Pakai 'ssh remove $name' dulu kalau mau ganti."

    c_cyan "== Bikin koneksi baru: $name =="

    echo "Metode koneksi:"
    echo "  1) Host + User + Password"
    echo "  2) Host + User + SSH key (file)"
    echo "  3) Connection string langsung (contoh: tmate -> token@host)"
    read -rp "Pilih [1/2/3]  : " method

    if [ "$method" = "3" ]; then
        read -rp "Connection string (user@host): " connstr
        [ -z "$connstr" ] && die "Connection string wajib diisi."
        read -rp "Port [22]      : " port
        port="${port:-22}"
        {
            echo "AUTH=connstr"
            echo "CONNSTR=$connstr"
            echo "PORT=$port"
        } > "$file"
        chmod 600 "$file"
        c_green "✓ Koneksi '$name' berhasil disimpan."
        echo "  Connect dengan: ssh connect $name"
        return
    fi

    read -rp "Host/IP        : " host
    [ -z "$host" ] && die "Host wajib diisi."

    read -rp "User           : " user
    [ -z "$user" ] && user="root"

    read -rp "Port [22]      : " port
    port="${port:-22}"

    {
        echo "HOST=$host"
        echo "SSH_USER=$user"
        echo "PORT=$port"
    } > "$file"

    if [ "$method" = "2" ]; then
        read -rp "Path ke private key (contoh: ~/.ssh/id_rsa): " keypath
        keypath="${keypath/#\~/$HOME}"
        [ -f "$keypath" ] || die "File key tidak ditemukan: $keypath"
        echo "AUTH=key" >> "$file"
        echo "KEYPATH=$keypath" >> "$file"
    else
        require_openssl
        read -rsp "Password SSH   : " sshpass_val
        echo
        read -rsp "Master password (buat enkripsi, jangan lupa!): " masterpass
        echo
        local enc
        enc="$(encrypt_str "$sshpass_val" "$masterpass")"
        echo "AUTH=password" >> "$file"
        echo "PASSENC=$enc" >> "$file"
    fi

    chmod 600 "$file"
    c_green "✓ Koneksi '$name' berhasil disimpan."
    echo "  Connect dengan: ssh connect $name"
}

cmd_list() {
    if [ -z "$(ls -A "$CONN_DIR" 2>/dev/null)" ]; then
        c_yellow "Belum ada koneksi tersimpan. Bikin dulu: ssh create <nama>"
        return
    fi
    c_cyan "== Daftar koneksi =="
    for f in "$CONN_DIR"/*.conf; do
        local name
        name="$(basename "$f" .conf)"
        # shellcheck disable=SC1090
        source "$f"
        if [ "$AUTH" = "connstr" ]; then
            printf "  %-15s %s:%s (connstr)\n" "$name" "$CONNSTR" "$PORT"
        else
            printf "  %-15s %s@%s:%s (%s)\n" "$name" "$SSH_USER" "$HOST" "$PORT" "$AUTH"
        fi
    done
}

cmd_remove() {
    local name="${1:-}"
    [ -z "$name" ] && die "Nama koneksi wajib diisi. Contoh: ssh remove myvps"
    local file
    file="$(conn_file "$name")"
    [ -f "$file" ] || die "Koneksi '$name' tidak ditemukan."
    rm -f "$file"
    c_green "✓ Koneksi '$name' dihapus."
}

cmd_connect() {
    local name="${1:-}"
    [ -z "$name" ] && die "Nama koneksi wajib diisi. Contoh: ssh connect myvps"
    local file
    file="$(conn_file "$name")"
    [ -f "$file" ] || die "Koneksi '$name' tidak ditemukan. Cek: ssh list"

    # shellcheck disable=SC1090
    source "$file"

    echo "$name" > "$ACTIVE_FILE"

    # Opsi buat mempercepat koneksi:
    # - GSSAPIAuthentication=no  : skip nyoba Kerberos/GSSAPI auth (sering bikin delay beberapa detik)
    # - ConnectTimeout=10        : jangan nunggu lama kalau server gak respons
    local speed_opts=(-o GSSAPIAuthentication=no -o ConnectTimeout=10 -o ServerAliveInterval=15)

    if [ "$AUTH" = "key" ]; then
        c_green "→ Menghubungkan ke $SSH_USER@$HOST:$PORT (key: $KEYPATH)..."
        "$REAL_SSH" "${speed_opts[@]}" -i "$KEYPATH" -p "$PORT" "$SSH_USER@$HOST"
    elif [ "$AUTH" = "connstr" ]; then
        c_green "→ Menghubungkan via connection string ($CONNSTR:$PORT)..."
        "$REAL_SSH" "${speed_opts[@]}" -p "$PORT" "$CONNSTR"
    else
        require_openssl
        command -v sshpass >/dev/null 2>&1 || die "sshpass belum terinstall. Jalankan: pkg install sshpass"
        local plain
        ask_master_pass "Master password: "
        plain="$(decrypt_str "$PASSENC" "$ASKED_PASS" || true)"
        ASKED_PASS=""
        [ -z "$plain" ] && die "Master password salah atau data corrupt."
        c_green "→ Menghubungkan ke $SSH_USER@$HOST:$PORT..."
        sshpass -p "$plain" "$REAL_SSH" "${speed_opts[@]}" -o StrictHostKeyChecking=accept-new -o PreferredAuthentications=password -o PubkeyAuthentication=no -p "$PORT" "$SSH_USER@$HOST"
        unset plain
    fi

    rm -f "$ACTIVE_FILE"
}

cmd_dc() {
    if [ ! -f "$ACTIVE_FILE" ]; then
        c_yellow "Tidak ada session SSH aktif yang tercatat."
        echo "Kalau kamu masih di dalam sesi SSH, cukup ketik 'exit' atau tekan Ctrl+D."
        return
    fi
    local name
    name="$(cat "$ACTIVE_FILE")"
    c_yellow "Session '$name' tercatat aktif, tapi 'dc' dari luar sesi tidak bisa memutus paksa koneksi TTY."
    echo "Masuk ke sesi tersebut dan ketik 'exit', atau tutup session Termux-nya."
    rm -f "$ACTIVE_FILE"
}

cmd_restore() {
    local bin_dir
    bin_dir="$(dirname "$REAL_SSH")"
    local sshm_path="$bin_dir/sshm"
    local ssh_path="$bin_dir/ssh"

    c_cyan "== Mengembalikan 'ssh' ke openssh bawaan =="

    if ! command -v pkg >/dev/null 2>&1; then
        die "Command 'pkg' tidak ditemukan. Restore otomatis hanya didukung di Termux."
    fi

    read -rp "Ini akan reinstall paket openssh dan menghapus command 'sshm'. Lanjut? [y/N] " confirm
    case "$confirm" in
        y|Y) ;;
        *) echo "Dibatalkan."; return ;;
    esac

    echo "Menghapus wrapper 'ssh' lama..."
    rm -f "$ssh_path"

    echo "Reinstall paket openssh (memulihkan binary ssh asli)..."
    pkg reinstall -y openssh || pkg install -y --reinstall openssh || die "Gagal reinstall openssh. Coba manual: pkg reinstall openssh"

    if [ -f "$sshm_path" ]; then
        read -rp "Hapus juga command 'sshm' dan semua koneksi tersimpan? [y/N] " confirm2
        case "$confirm2" in
            y|Y)
                rm -f "$sshm_path"
                rm -rf "$CONF_DIR"
                c_green "✓ 'sshm' dan semua koneksi tersimpan sudah dihapus."
                ;;
            *)
                echo "'sshm' tetap disimpan, cuma command 'ssh' yang dikembalikan ke openssh bawaan."
                ;;
        esac
    fi

    hash -r 2>/dev/null || true
    c_green "✓ Command 'ssh' sudah dikembalikan ke openssh bawaan Termux."
}

cmd_help() {
    cat <<EOF
$(c_cyan "SSH Manager - Termux")

  ssh create <nama>     Bikin koneksi baru (interaktif, pilih password/key)
  ssh connect <nama>    Konek ke koneksi tersimpan
  ssh list              Lihat semua koneksi tersimpan
  ssh remove <nama>     Hapus koneksi tersimpan
  ssh dc                Info soal session aktif / cara disconnect
  ssh restore           Kembalikan command 'ssh' ke openssh bawaan (uninstall)
  ssh <user>@<host>     Passthrough ke ssh biasa (fitur normal tetap jalan)

Contoh:
  ssh create vps1
  ssh connect vps1
  ssh list
  ssh remove vps1
  ssh restore
EOF
}

# ---------- main ----------

main() {
    local cmd="${1:-}"
    case "$cmd" in
        create)  shift; cmd_create "${1:-}";;
        connect) shift; cmd_connect "${1:-}";;
        list)    cmd_list;;
        remove|rm) shift; cmd_remove "${1:-}";;
        dc|disconnect) cmd_dc;;
        restore|uninstall) cmd_restore;;
        help|-h|--help|"") cmd_help;;
        *)
            # passthrough ke ssh asli biar tetap kompatibel: ssh user@host
            exec "$REAL_SSH" "$@"
            ;;
    esac
}

main "$@"
