#!/data/data/com.termux/files/usr/bin/bash
#
# sshm — SSH Connection Manager for Termux
# Usage:
#   ssh create <name>       Create a new saved connection
#   ssh connect <name>      Connect to a saved connection
#   ssh list                List all saved connections
#   ssh remove <name>       Remove a saved connection
#   ssh dc                  Info about active SSH session
#   ssh restore             Restore original ssh binary
#   ssh <user>@<host> [...] Passthrough to real ssh
#
set -euo pipefail

# ─── Paths ────────────────────────────────────────────────────────────────────
CONF_DIR="$HOME/.ssh-manager"
CONN_DIR="$CONF_DIR/connections"
ACTIVE_FILE="$CONF_DIR/active_session"
THIS_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"

# Find the REAL openssh binary — never trust `command -v ssh`, since if this
# wrapper is installed as /usr/bin/ssh, that resolves back to itself and
# causes an infinite self-exec loop (looks like a "stuck"/hung connection).
find_real_ssh() {
  local candidates=(
    "$(command -v ssh.real 2>/dev/null || true)"
    "/data/data/com.termux/files/usr/bin/ssh.real"
    "/data/data/com.termux/files/usr/bin/ssh"
  )
  for c in "${candidates[@]}"; do
    [ -z "$c" ] && continue
    [ -x "$c" ] || continue
    local resolved; resolved="$(readlink -f "$c" 2>/dev/null || echo "$c")"
    [ "$resolved" = "$THIS_SCRIPT" ] && continue
    echo "$c"
    return 0
  done
  return 1
}

REAL_SSH="$(find_real_ssh || true)"
if [ -z "$REAL_SSH" ]; then
  echo "✗ Cannot find the real openssh binary (only found this wrapper itself)." >&2
  echo "  This usually happens if 'ssh' was overwritten without backing up the original." >&2
  echo "  Fix: pkg reinstall -y openssh   (then re-install this wrapper as 'sshm', not 'ssh')" >&2
  exit 1
fi

mkdir -p "$CONN_DIR"
chmod 700 "$CONF_DIR" "$CONN_DIR"

# ─── Colors ───────────────────────────────────────────────────────────────────
R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m'
C='\033[1;36m' B='\033[1;34m' W='\033[1;37m'
DIM='\033[2m' RESET='\033[0m'

# ─── Helpers ──────────────────────────────────────────────────────────────────
c_green()  { printf "${G}%s${RESET}\n" "$1"; }
c_red()    { printf "${R}%s${RESET}\n" "$1"; }
c_yellow() { printf "${Y}%s${RESET}\n" "$1"; }
c_cyan()   { printf "${C}%s${RESET}\n" "$1"; }
c_dim()    { printf "${DIM}%s${RESET}\n" "$1"; }

die() { printf "${R}  ✗ %s${RESET}\n" "$1"; exit 1; }
ok()  { printf "${G}  ✔ %s${RESET}\n" "$1"; }
info(){ printf "${C}  ➜ %s${RESET}\n" "$1"; }
warn(){ printf "${Y}  ⚠ %s${RESET}\n" "$1"; }

box() {
  local title="$1"
  local width=46
  local line
  line=$(printf '─%.0s' $(seq 1 $width))
  printf "\n${C}┌${line}┐${RESET}\n"
  printf "${C}│${W}  %-${width}s${C}│${RESET}\n" "$title"
  printf "${C}└${line}┘${RESET}\n\n"
}

conn_file() { echo "$CONN_DIR/$1.conf"; }

require_openssl() {
  command -v openssl >/dev/null 2>&1 \
    || die "openssl not installed. Run: pkg install openssl-tool"
}

# ─── Encrypt / Decrypt ────────────────────────────────────────────────────────
encrypt_str() {
  printf '%s' "$1" | openssl enc -aes-256-cbc -pbkdf2 -salt -pass pass:"$2" -base64
}
decrypt_str() {
  printf '%s\n' "$1" | openssl enc -aes-256-cbc -pbkdf2 -d -salt -pass pass:"$2" -base64 2>/dev/null
}

ASKED_PASS=""
ask_master_pass() {
  read -rsp "  $1: " ASKED_PASS; echo
}

# ─── SSH fast options ─────────────────────────────────────────────────────────
# Breakdown of each flag:
#   GSSAPIAuthentication=no   — skip Kerberos/GSSAPI handshake (~2-5s delay if enabled)
#   AddressFamily=inet         — force IPv4, skip IPv6 DNS lookup
#   ConnectTimeout=8           — give up faster if host unreachable
#   ServerAliveInterval=30     — keepalive ping every 30s (prevent idle timeout)
#   ServerAliveCountMax=3      — disconnect after 3 missed pings
#   Compression=no             — disable compression (faster on good connections)
#   IPQoS=lowdelay             — mark packets as low-latency (QoS hint)
#   LogLevel=ERROR             — suppress verbose SSH noise
FAST_OPTS=(
  -o GSSAPIAuthentication=no
  -o AddressFamily=inet
  -o ConnectTimeout=8
  -o ServerAliveInterval=30
  -o ServerAliveCountMax=3
  -o Compression=no
  -o IPQoS=lowdelay
  -o LogLevel=ERROR
)

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_create() {
  local name="${1:-}"
  [ -z "$name" ] && die "Connection name required. Example: ssh create myvps"

  local file; file="$(conn_file "$name")"
  [ -f "$file" ] && die "Connection '$name' already exists. Run 'ssh remove $name' first."

  box "New Connection: $name"

  printf "  Auth method:\n"
  printf "  ${W}1)${RESET} Host + Username + Password\n"
  printf "  ${W}2)${RESET} Host + Username + SSH Key (file)\n"
  printf "  ${W}3)${RESET} Connection string (e.g. tmate token)\n\n"
  read -rp "  Choice [1/2/3]: " method

  if [ "$method" = "3" ]; then
    read -rp "  Connection string (user@host): " connstr
    [ -z "$connstr" ] && die "Connection string is required."
    read -rp "  Port [22]: " port; port="${port:-22}"
    { echo "AUTH=connstr"; echo "CONNSTR=$connstr"; echo "PORT=$port"; } > "$file"
    chmod 600 "$file"
    echo ""; ok "Connection '$name' saved."
    c_dim "  Connect with: ssh connect $name"
    return
  fi

  read -rp "  Host/IP: " host; [ -z "$host" ] && die "Host is required."
  read -rp "  Username [root]: " user; user="${user:-root}"
  read -rp "  Port [22]: " port; port="${port:-22}"

  { echo "HOST=$host"; echo "SSH_USER=$user"; echo "PORT=$port"; } > "$file"

  if [ "$method" = "2" ]; then
    read -rp "  Private key path (e.g. ~/.ssh/id_rsa): " keypath
    keypath="${keypath/#\~/$HOME}"
    [ -f "$keypath" ] || die "Key file not found: $keypath"
    { echo "AUTH=key"; echo "KEYPATH=$keypath"; } >> "$file"
  else
    require_openssl
    read -rsp "  SSH Password: " sshpass_val; echo
    read -rsp "  Master password (for encryption — don't forget this!): " masterpass; echo
    local enc; enc="$(encrypt_str "$sshpass_val" "$masterpass")"
    { echo "AUTH=password"; echo "PASSENC=$enc"; } >> "$file"
  fi

  chmod 600 "$file"
  echo ""; ok "Connection '$name' saved."
  c_dim "  Connect with: ssh connect $name"
}

cmd_list() {
  local files=("$CONN_DIR"/*.conf)
  if [ ! -f "${files[0]:-}" ]; then
    warn "No saved connections. Create one: ssh create <name>"
    return
  fi

  box "Saved Connections"

  local idx=0
  for f in "$CONN_DIR"/*.conf; do
    local name; name="$(basename "$f" .conf)"
    # shellcheck disable=SC1090
    source "$f"
    idx=$((idx+1))

    if [ "$AUTH" = "connstr" ]; then
      printf "  ${W}%2d)${RESET} %-16s ${DIM}%s:%-5s${RESET} ${C}[connstr]${RESET}\n" \
        "$idx" "$name" "$CONNSTR" "$PORT"
    elif [ "$AUTH" = "key" ]; then
      printf "  ${W}%2d)${RESET} %-16s ${DIM}%s@%s:%-5s${RESET} ${C}[key]${RESET}\n" \
        "$idx" "$name" "$SSH_USER" "$HOST" "$PORT"
    else
      printf "  ${W}%2d)${RESET} %-16s ${DIM}%s@%s:%-5s${RESET} ${Y}[password]${RESET}\n" \
        "$idx" "$name" "$SSH_USER" "$HOST" "$PORT"
    fi
  done
  echo ""
}

cmd_remove() {
  local name="${1:-}"
  [ -z "$name" ] && die "Name required. Example: ssh remove myvps"
  local file; file="$(conn_file "$name")"
  [ -f "$file" ] || die "Connection '$name' not found."
  rm -f "$file"
  ok "Connection '$name' removed."
}

cmd_connect() {
  local name="${1:-}"
  [ -z "$name" ] && die "Name required. Example: ssh connect myvps"
  local file; file="$(conn_file "$name")"
  [ -f "$file" ] || die "Connection '$name' not found. Check: ssh list"

  # shellcheck disable=SC1090
  source "$file"
  echo "$name" > "$ACTIVE_FILE"

  if [ "$AUTH" = "key" ]; then
    printf "\n${G}  ◉ Connecting ${W}%s@%s${G}:%s ${DIM}(key auth)${RESET}\n\n" \
      "$SSH_USER" "$HOST" "$PORT"
    "$REAL_SSH" "${FAST_OPTS[@]}" -i "$KEYPATH" -p "$PORT" "$SSH_USER@$HOST"

  elif [ "$AUTH" = "connstr" ]; then
    printf "\n${G}  ◉ Connecting via connection string ${W}%s${G}:%s${RESET}\n\n" \
      "$CONNSTR" "$PORT"
    "$REAL_SSH" "${FAST_OPTS[@]}" -p "$PORT" "$CONNSTR"

  else
    require_openssl
    command -v sshpass >/dev/null 2>&1 \
      || die "sshpass not installed. Run: pkg install sshpass"

    ask_master_pass "Master password"
    local plain; plain="$(decrypt_str "$PASSENC" "$ASKED_PASS" || true)"
    ASKED_PASS=""
    [ -z "$plain" ] && die "Wrong master password or corrupted data."

    printf "\n${G}  ◉ Connecting ${W}%s@%s${G}:%s ${DIM}(password auth)${RESET}\n\n" \
      "$SSH_USER" "$HOST" "$PORT"

    sshpass -p "$plain" "$REAL_SSH" "${FAST_OPTS[@]}" \
      -o StrictHostKeyChecking=accept-new \
      -o PreferredAuthentications=password \
      -o PubkeyAuthentication=no \
      -p "$PORT" "$SSH_USER@$HOST"
    unset plain
  fi

  rm -f "$ACTIVE_FILE"
}

cmd_dc() {
  if [ ! -f "$ACTIVE_FILE" ]; then
    warn "No active SSH session recorded."
    c_dim "  If you are inside an SSH session, type 'exit' or press Ctrl+D."
    return
  fi
  local name; name="$(cat "$ACTIVE_FILE")"
  warn "Session '$name' is recorded as active."
  c_dim "  You can't force-disconnect a TTY session from outside."
  c_dim "  Go into the session and type 'exit', or close the Termux window."
  rm -f "$ACTIVE_FILE"
}

cmd_restore() {
  local bin_dir; bin_dir="$(dirname "$REAL_SSH")"

  box "Restore Original SSH"

  command -v pkg >/dev/null 2>&1 \
    || die "Command 'pkg' not found. Auto-restore only supported on Termux."

  read -rp "  This will reinstall openssh and remove the 'sshm' wrapper. Continue? [y/N] " confirm
  case "$confirm" in y|Y) ;; *) echo "  Cancelled."; return ;; esac

  echo ""
  if [ -f "$bin_dir/ssh.real" ]; then
    info "Restoring original ssh binary from backup..."
    mv -f "$bin_dir/ssh.real" "$bin_dir/ssh"
    chmod +x "$bin_dir/ssh"
  else
    info "No backup found — reinstalling openssh package instead..."
    rm -f "$bin_dir/ssh"
    pkg reinstall -y openssh 2>/dev/null \
      || pkg install -y --reinstall openssh \
      || die "Failed to reinstall openssh. Try manually: pkg reinstall openssh"
  fi

  if [ -f "$bin_dir/sshm" ]; then
    read -rp "  Also remove 'sshm' command and all saved connections? [y/N] " confirm2
    case "$confirm2" in
      y|Y)
        rm -f "$bin_dir/sshm"
        rm -rf "$CONF_DIR"
        ok "'sshm' and all saved connections removed."
        ;;
      *)
        c_dim "  'sshm' kept. Only 'ssh' was restored to original."
        ;;
    esac
  fi

  hash -r 2>/dev/null || true
  echo ""; ok "Original 'ssh' command restored."
}

cmd_help() {
  local w=46
  local line; line=$(printf '─%.0s' $(seq 1 $w))
  printf "\n${C}┌${line}┐${RESET}\n"
  printf "${C}│${W}  %-${w}s${C}│${RESET}\n" "SSH Manager for Termux"
  printf "${C}├${line}┤${RESET}\n"
  printf "${C}│${RESET}  %-${w}s${C}│${RESET}\n" ""
  printf "${C}│${RESET}  ${G}ssh create${W} <name>     ${RESET}%-16s${C}│${RESET}\n" "Save a new connection"
  printf "${C}│${RESET}  ${G}ssh connect${W} <name>    ${RESET}%-16s${C}│${RESET}\n" "Connect to saved session"
  printf "${C}│${RESET}  ${G}ssh list${RESET}               %-16s${C}│${RESET}\n"   "List saved connections"
  printf "${C}│${RESET}  ${G}ssh remove${W} <name>     ${RESET}%-16s${C}│${RESET}\n" "Delete a saved connection"
  printf "${C}│${RESET}  ${G}ssh dc${RESET}                 %-16s${C}│${RESET}\n"   "Active session info"
  printf "${C}│${RESET}  ${G}ssh restore${RESET}            %-16s${C}│${RESET}\n"   "Restore original ssh"
  printf "${C}│${RESET}  ${G}ssh${W} user@host${RESET}          %-16s${C}│${RESET}\n" "Passthrough to real ssh"
  printf "${C}│${RESET}  %-${w}s${C}│${RESET}\n" ""
  printf "${C}├${line}┤${RESET}\n"
  printf "${C}│${DIM}  %-${w}s${C}│${RESET}\n" "Examples:"
  printf "${C}│${RESET}  ${DIM}ssh create myvps${RESET}%-$((w-16))s${C}│${RESET}\n" ""
  printf "${C}│${RESET}  ${DIM}ssh connect myvps${RESET}%-$((w-17))s${C}│${RESET}\n" ""
  printf "${C}│${RESET}  ${DIM}ssh list${RESET}%-$((w-8))s${C}│${RESET}\n" ""
  printf "${C}│${RESET}  %-${w}s${C}│${RESET}\n" ""
  printf "${C}└${line}┘${RESET}\n\n"
}

# ─── Main ─────────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-}"
  case "$cmd" in
    create)            shift; cmd_create "${1:-}" ;;
    connect)           shift; cmd_connect "${1:-}" ;;
    list|ls)           cmd_list ;;
    remove|rm|delete)  shift; cmd_remove "${1:-}" ;;
    dc|disconnect)     cmd_dc ;;
    restore|uninstall) cmd_restore ;;
    help|-h|--help|"") cmd_help ;;
    *)
      # passthrough — so `ssh user@host` still works normally
      exec "$REAL_SSH" "$@"
      ;;
  esac
}

main "$@"
