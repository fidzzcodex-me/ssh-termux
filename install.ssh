#!/data/data/com.termux/files/usr/bin/bash
set -e

echo "Installing SSH Manager buat Termux..."

pkg install -y openssl-tool sshpass openssh >/dev/null 2>&1 || {
    echo "Pastikan kamu jalanin ini di Termux dan koneksi internet aktif."
}

mkdir -p "$PREFIX/bin"
cp ssh "$PREFIX/bin/sshm"
chmod +x "$PREFIX/bin/sshm"

echo "✓ Terinstall sebagai command: sshm"
echo ""
echo "Kenapa 'sshm' bukan 'ssh'? Supaya command ssh bawaan Termux tidak ketiban/rusak."
echo "Kalau kamu YAKIN mau override command 'ssh' sepenuhnya, jalankan:"
echo "  cp ssh \$PREFIX/bin/ssh && chmod +x \$PREFIX/bin/ssh"
echo ""
echo "Contoh pemakaian:"
echo "  sshm create myvps"
echo "  sshm connect myvps"
echo "  sshm list"
